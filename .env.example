# QA Tool Configuration
# Remote QA server (for most developers)
QA_URL="http://YOUR-QA-SERVER:PORT"
QA_USER="your-username"
QA_PASS="your-password"

# Local QA server (optional - only if you have qa-tool locally)
QA_URL_LOCAL="http://localhost:8884"

# QA Tool Directory (optional - only if you have qa-tool locally)
# QA_TOOL_DIR="$HOME/Data/b8bz8z5a/qa-tool"

# Environments to run (default)
QA_ENVS="preprod-avg"

# GChat Webhooks
# Ask your team lead for the actual webhook URLs

# Testing webhook (use during development)
GCHAT_WEBHOOK_TEST="https://chat.googleapis.com/v1/spaces/YOUR-TEST-WEBHOOK-HERE"

# Production webhook (use after approval)
GCHAT_WEBHOOK="https://chat.googleapis.com/v1/spaces/YOUR-PROD-WEBHOOK-HERE"

# Optional: Other webhooks for reference
# GCHAT_WEBHOOK_PROD="https://chat.googleapis.com/v1/spaces/YOUR-PROD-WEBHOOK-HERE"

# Other Configuration (optional)
UPTIMEROBOT_API_KEY=""
JIRA_API_ACCESS_TOKEN=""
